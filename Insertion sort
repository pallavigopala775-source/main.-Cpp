#include <stdio.h>

int main() {

    int arr[5] = {9, 5, 1, 4, 3};
    int i, j, temp;

    for(i = 1; i < 5; i++) {

        temp = arr[i];
        j = i - 1;

        while(j >= 0 && arr[j] > temp) {

            arr[j + 1] = arr[j];
            j--;
        }

        arr[j + 1] = temp;
    }

    printf("Sorted Array:\n");

    for(i = 0; i < 5; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
