#include <stdio.h>

int stack[5];
int top = -1;

void push(int value) {

    if(top == 4)
        printf("Stack Overflow\n");

    else {
        top++;
        stack[top] = value;
        printf("Inserted %d\n", value);
    }
}

void display() {

    int i;

    if(top == -1)
        printf("Stack is Empty");

    else {

        printf("Stack Elements:\n");

        for(i = top; i >= 0; i--) {
            printf("%d\n", stack[i]);
        }
    }
}

int main() {

    push(10);
    push(20);
    push(30);

    display();

    return 0;
}
