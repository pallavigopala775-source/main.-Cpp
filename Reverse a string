#include <iostream>
#include <cstring>

using namespace std;

int main()
{
    char str[50];

    cout << "Enter a string: ";
    cin.getline(str, 50);

    int first = 0;
    int last = strlen(str) - 1;

    while(first < last)
    {
        char ch = str[first];
        str[first] = str[last];
        str[last] = ch;

        first++;
        last--;
    }

    cout << "Reversed string is: " << str;

    return 0;
}
